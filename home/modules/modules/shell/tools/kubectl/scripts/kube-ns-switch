#!/usr/bin/env bash
# Switch default namespace for current context

set -euo pipefail

namespace="${1:-}"

if [[ -z "$namespace" ]]; then
  namespace=$(kubectl get namespaces -o jsonpath='{.items[*].metadata.name}' | tr ' ' '\n' | fzf --prompt="Select namespace: ")
fi

if [[ -n "$namespace" ]]; then
  context=$(kubectl config current-context)
  kubectl config set-context "$context" --namespace="$namespace"
  echo -e "\033[32mNamespace switched to: $namespace\033[0m"
fi
